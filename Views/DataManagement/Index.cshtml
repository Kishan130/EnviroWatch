@using EnviroWatch.Models
@{
    ViewData["Title"] = "Data Management";
    var districts = ViewBag.Districts as List<District>;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 font-outfit fw-bold text-gradient">Data Management</h1>
            <p class="text-muted">Populate and manage historical data for your dashboard.</p>
        </div>
        <div class="badge bg-primary-soft text-primary p-2 px-3 rounded-pill">
            <i class="fas fa-database me-2"></i> Admin Portal
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Auto Seeding Card -->
        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-gradient-primary text-white p-4 border-0">
                    <h3 class="h5 mb-1"><i class="fas fa-cloud-download-alt me-2"></i> Seed Historical Data</h3>
                    <p class="small mb-0 opacity-75">Automatically fetch the last 30 days of real data from API.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="SeedHistory" method="post" id="seedForm">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Select District</label>
                            <select name="districtId" class="form-select form-select-lg border-2">
                                <option value="">-- All Districts --</option>
                                @foreach (var d in districts ?? new List<District>())
                                {
                                    <option value="@d.Id">@d.Name, @d.State</option>
                                }
                            </select>
                            <div class="form-text mt-2">
                                <i class="fas fa-info-circle me-1"></i> This counts towards your API rate limits. 
                                Fetching for all districts may take a moment.
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-3 mt-3 shadow-sm rounded-3 fw-bold" id="btnSeed">
                            <i class="fas fa-magic me-2"></i> Start Automated Seeding
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Bulk Import Card -->
        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-gradient-success text-white p-4 border-0">
                    <h3 class="h5 mb-1"><i class="fas fa-file-import me-2"></i> Bulk CSV Import</h3>
                    <p class="small mb-0 opacity-75">Manually paste data records into the database.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="BulkInsert" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Target District</label>
                            <select name="districtId" class="form-select border-2" required>
                                @foreach (var d in districts ?? new List<District>())
                                {
                                    <option value="@d.Id">@d.Name, @d.State</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Data (Format: Date, AQI, Temp)</label>
                            <textarea name="csvData" class="form-control border-2 font-monospace" rows="5" placeholder="2024-03-01, 45, 22.5&#10;2024-03-02, 55, 23.0"></textarea>
                            <div class="form-text mt-2">Format: <code>YYYY-MM-DD, AQI, Temperature</code> (one per line)</div>
                        </div>
                        <button type="submit" class="btn btn-success w-100 py-3 shadow-sm rounded-3 fw-bold">
                            <i class="fas fa-upload me-2"></i> Import Records
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gradient {
        background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .bg-gradient-primary {
        background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
    }
    .bg-gradient-success {
        background: linear-gradient(135deg, #059669 0%, #10b981 100%);
    }
    .bg-primary-soft {
        background-color: rgba(37, 99, 235, 0.1);
    }
    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 1.25rem;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
    }
    .form-select, .form-control {
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
    }
    .form-select:focus, .form-control:focus {
        box-shadow: 0 0 0 0.25rem rgba(37, 99, 235, 0.15);
        border-color: #3b82f6;
    }
</style>

@section Scripts {
    <script>
        document.getElementById('seedForm').addEventListener('submit', function() {
            const btn = document.getElementById('btnSeed');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Seeding in progress...';
        });
    </script>
}
